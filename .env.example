# Notion: create an internal integration, share the Production database with it.
NOTION_TOKEN=secret_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# After Notion sends the one-time verification POST, copy the token from Vercel logs
# and paste it here so incoming events can be checked (X-Notion-Signature).
# NOTION_WEBHOOK_VERIFICATION_TOKEN=secret_paste_from_verification_payload

# Telegram: create a bot with BotFather.
TELEGRAM_BOT_TOKEN=123456789:AA-your-bot-token-from-botfather

# Public URL of this Next.js app (no trailing slash), used by set-webhook helper.
NEXT_PUBLIC_APP_URL=https://anvance-bot-production.vercel.app

# Optional: 1–256 chars, only A–Z a–z 0–9 _ - (Telegram rule). NOT the bot token (contains ':').
# Example: output of openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=abcdef0123456789abcdef0123456789

# One-time setup: protect /api/telegram/set-webhook?secret= and optional
# GET /api/notion/webhook?secret= (read last Notion verification_token; best-effort on Vercel).
ADMIN_SETUP_SECRET=long-random-admin-secret

# Map Telegram user id -> assignee display string as it appears in Notion (People names or plain text).
# Example: {"123456789":"Albert Rhey Embalsado"}
TELEGRAM_USER_ASSIGNEE_MAP={}

# If your Notion property labels differ from the CSV export, override them here.
# NOTION_PROP_NAME=Name
# NOTION_PROP_ASSIGNEE=Assignee
# NOTION_PROP_DUE=Due date
# NOTION_PROP_SHOOT=Shoot / live date
# NOTION_PROP_STATUS=Status
# NOTION_PROP_PRIORITY=Priority
# NOTION_PROP_DELIVERABLE=Deliverable
# NOTION_PROP_CLIENT=Client
# NOTION_PROP_SERVICE_LINE=Service line
